{
  "shop_system": {
    "version": "1.0",
    "design_notes": [
      "Shops are anchored to settlement archetypes and biome scarcity.",
      "Merchants can accept multiple currency modes: coin, barter, information, favors, or scarce local goods.",
      "Each shop instance should generate standard stock, uncommon mundane stock, magic flavor stock, and optional rare stock.",
      "Avoid trademarked D&D item names. Use generalized equivalents.",
      "Flavor magic items should be common in the setting even when not combat-optimized."
    ]
  },

  "currency_types": [
    {
      "id": "coin",
      "name": "Coin",
      "description": "Generic minted currency or trade metal used for basic exchange.",
      "valuation_style": "stable"
    },
    {
      "id": "barter",
      "name": "Barter",
      "description": "Direct trade of practical goods.",
      "valuation_style": "contextual"
    },
    {
      "id": "information",
      "name": "Information",
      "description": "Useful rumors, route knowledge, names, access phrases, or local secrets.",
      "valuation_style": "volatile"
    },
    {
      "id": "favor",
      "name": "Favor",
      "description": "A promise of future help, protection, escort, repair, delivery, or influence.",
      "valuation_style": "social"
    },
    {
      "id": "scarce_local_good",
      "name": "Scarce Local Good",
      "description": "A good unusually scarce or valuable in the local biome or settlement.",
      "valuation_style": "highly_contextual"
    }
  ],

