  "merchant_generation_rules": {
    "stock_generation_order": [
      "1. Resolve shop_type",
      "2. Resolve settlement_archetype",
      "3. Resolve biome_trade_profile",
      "4. Determine accepted currency types",
      "5. Determine scarcity modifiers from biome + settlement",
