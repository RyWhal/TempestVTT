{
  "items_schema": {
    "version": "1.0",
    "notes": [
      "Item names avoid trademarked D&D-specific terms.",
      "Items are templates, not per-instance objects.",
      "Instance-specific fields such as durability, owner, quantity, discovered_at, and room_id should be stored separately in item_instance records.",
      "Magic items in this pack skew toward utility, flavor, atmosphere, logistics, and world richness rather than pure combat optimization."
    ],
    "required_fields": [
      "id",
      "name",
      "category_id",
      "subcategory_id",
      "rarity",
      "base_value",
      "value_scale",
      "trade_tags",
      "stackable",
      "weight_class",
      "legal_for_shops",
      "description"
    ],
    "optional_fields": [
      "consumable",
      "charges",
      "max_charges",
      "recharge_rule",
      "magic_effect_summary",
      "usage_notes",
      "durability_class",
