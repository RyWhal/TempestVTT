{
  "schema_version": "1.0",
  "pipeline_id": "tempest_visual_bake_v1",
  "description": "Server-side procedural floor bake pipeline for Tempest Table.",
  "render_strategy": {
    "mode": "server_baked",
    "bake_output": "chunked_images",
    "chunk_size_px": 1024,
    "tile_resolution_px": 64,
    "floor_cells_per_chunk": 16,
    "image_format": "svg",
    "image_quality": 1,
    "cache_baked_chunks": true,
    "rebake_policy": "dirty_chunks_only"
  },
  "environment_layers": {
    "baked_wall_stamps_enabled": true,
    "baked_grit_enabled": false
  },
  "seed_rules": {
    "map_seed_required": true,
    "cell_seed_formula": "hash(map_seed, biome_id, cell_x, cell_y)",
    "chunk_seed_formula": "hash(map_seed, chunk_x, chunk_y)"
  },
  "grid_rules": {
    "cell_shape": "square",
    "rotation_step_degrees": 90,
    "allow_rotation": true,
    "allow_horizontal_flip": true,
    "allow_vertical_flip": false
  },
  "tile_selection_rules": {
    "selection_mode": "weighted_seeded_random",
    "avoid_adjacent_identical_tiles": true,
    "avoid_2x2_identical_blocks": true,
    "local_repeat_penalty_radius": 2,
    "respect_rotation_safety_flags": true,
    "respect_flip_safety_flags": true
  },
  "composition_passes": [
    {
      "id": "base_floor",
      "enabled": true,
      "blend_mode": "normal",
      "opacity": 1
    },
    {
      "id": "macro_variation",
      "enabled": true,
      "blend_mode": "multiply",
      "opacity": 0.14,
      "scale_multiplier": 4
    },
    {
      "id": "transition_blend",
      "enabled": true,
      "blend_mode": "normal",
      "opacity": 1
    },
    {
      "id": "detail_decals",
      "enabled": true,
      "blend_mode": "normal",
      "opacity": 0.85
    },
    {
      "id": "edge_breakup",
      "enabled": true,
      "blend_mode": "multiply",
      "opacity": 0.35
    }
  ],
  "transition_rules": {
    "enabled": true,
    "transition_band_width_cells": 2,
    "blend_mode": "feathered_mask",
    "prefer_declared_biome_transitions": true,
    "fallback_transition_mode": "neutral_blend"
  },
  "detail_decal_rules": {
    "enabled": true,
    "categories": ["fine_cracks", "moss_patches", "dirt_bleed", "small_rubble", "wet_spots"],
    "max_decals_per_chunk": 24,
    "min_spacing_cells": 1,
    "allow_overlap": false
  },
  "edge_breakup_rules": {
    "enabled": true,
    "apply_to_floor_adjacent_to_void": true,
    "darken_edges": true,
    "darken_opacity": 0.18,
    "spawn_edge_debris": true,
    "spawn_edge_moss": true,
    "irregularity_strength": 0.45
  },
  "performance_limits": {
    "max_map_width_cells": 256,
    "max_map_height_cells": 256,
    "parallel_chunk_jobs": 4
  },
  "debug_options": {
    "emit_debug_masks": false,
    "emit_variant_map": true,
    "emit_transition_map": true,
    "emit_chunk_manifest": true
  }
}
