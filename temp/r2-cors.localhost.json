{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "http://127.0.0.1:5173"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["Content-Length", "Content-Type", "ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
